#!/usr/bin/env bash
# ai-cli-container — launch an AI coding CLI in a Docker container

set -euo pipefail

IMAGE="claude-code-dev:latest"
SELF="$(basename "$0")"
TOOL_FLAVOR="claude"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUPPORT_DIR="${XDG_DATA_HOME:-${HOME}/.local/share}/ai-cli-container"
CODEX_AGENT_ASSET="${SUPPORT_DIR}/codex-agents/memory-bank-analyzer.toml"
if [ ! -f "$CODEX_AGENT_ASSET" ] && [ -f "${SCRIPT_DIR}/container-plugin/codex-agents/memory-bank-analyzer.toml" ]; then
  CODEX_AGENT_ASSET="${SCRIPT_DIR}/container-plugin/codex-agents/memory-bank-analyzer.toml"
fi
TMP_CODEX_OVERRIDE=""
TMP_CODEX_AGENTS_DIR=""

cleanup() {
  if [ -n "$TMP_CODEX_OVERRIDE" ] && [ -f "$TMP_CODEX_OVERRIDE" ]; then
    rm -f "$TMP_CODEX_OVERRIDE"
  fi
  if [ -n "$TMP_CODEX_AGENTS_DIR" ] && [ -d "$TMP_CODEX_AGENTS_DIR" ]; then
    rm -rf "$TMP_CODEX_AGENTS_DIR"
  fi
}

render_codex_override() {
  local host_codex_dir="$1"
  local dest_file="$2"

  {
    if [ -d "$host_codex_dir" ] && [ -s "${host_codex_dir}/AGENTS.override.md" ]; then
      cat "${host_codex_dir}/AGENTS.override.md"
      printf '\n\n'
    elif [ -d "$host_codex_dir" ] && [ -s "${host_codex_dir}/AGENTS.md" ]; then
      cat "${host_codex_dir}/AGENTS.md"
      printf '\n\n'
    fi

    cat <<'EOF'
# Global Codex Instructions

For any engineering task that involves implementing, changing, debugging, refactoring, testing, or reviewing code:

1. Before doing code analysis or edits, check whether the current working directory contains a `memory_bank/` directory.
2. If `memory_bank/` exists, immediately use the `memory-bank-analyzer` agent as the first sub-agent step after the task is defined.
3. Read and summarize the agent's findings, then continue with the task using that context.
4. If `memory_bank/` does not exist, note that briefly and proceed normally.

This rule applies across repositories.
EOF
  } > "$dest_file"
}

lookup_macos_keychain_secret() {
  local service="$1"

  if ! command -v security >/dev/null 2>&1; then
    return 1
  fi

  security find-generic-password -s "$service" -w 2>/dev/null
}

trap cleanup EXIT

if [[ "${1:-}" == "--container-help" || "${1:-}" == "-H" ]]; then
  cat <<HELP
Usage: $SELF [ARGS...] | [COMMAND...]

Launch ${SELF%%-container} in a Docker container with your current directory
mounted.

  claude-container                Launch Claude Code interactively
  claude-container --model opus   Pass flags to Claude Code
  codex-container                 Launch Codex CLI (--yolo added automatically)
  gemini-container                Launch Gemini CLI (--yolo added automatically)
  <either> bash                   Run an arbitrary command in the container
  <either> aws s3 ls              Use container tools directly
  <either> --container-help       Show launcher help

Environment variables (passed through when set):
  AWS_PROFILE              AWS profile to use
  AWS_REGION               AWS region for API calls
  CLAUDE_CODE_USE_BEDROCK  Set to 1 for AWS Bedrock
  AI_CLI_GITHUB_TOKEN      GitHub personal access token for gh CLI (falls back to macOS Keychain)
  OPENAI_API_KEY           OpenAI API key for Codex (falls back to macOS Keychain)
HELP
  exit 0
fi

# Prerequisite checks
if ! docker info >/dev/null 2>&1; then
  echo "Error: Docker is not running" >&2
  exit 1
fi
if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "Error: Image $IMAGE not found. Build it with:" >&2
  echo "  docker build -t $IMAGE ." >&2
  exit 1
fi

if [ -z "${AI_CLI_GITHUB_TOKEN:-}" ]; then
  AI_CLI_GITHUB_TOKEN="$(lookup_macos_keychain_secret AI_CLI_GITHUB_TOKEN || true)"
fi

# When invoked as an alternate launcher, inject the CLI command only when the
# user is launching the CLI itself rather than an arbitrary container command.
if [[ "$SELF" == "codex-container" ]]; then
  TOOL_FLAVOR="codex"
  if [ $# -eq 0 ] || [[ "${1:0:1}" == "-" ]] || [[ "${1:-}" == "resume" ]]; then
    if [ -z "${OPENAI_API_KEY:-}" ]; then
      OPENAI_API_KEY="$(lookup_macos_keychain_secret OPENAI_API_KEY)" || {
        echo "Error: OPENAI_API_KEY not found in environment or macOS Keychain" >&2
        echo "  Store it with: security add-generic-password -s OPENAI_API_KEY -a openai -w 'sk-...'" >&2
        exit 1
      }
    fi
    set -- codex --yolo "$@"
  fi
elif [[ "$SELF" == "gemini-container" ]]; then
  TOOL_FLAVOR="gemini"
  if [ $# -eq 0 ] || [[ "${1:0:1}" == "-" ]]; then
    set -- gemini --yolo "$@"
  fi
fi

# Get absolute path of current directory
PWD_ABS="$(pwd)"
PWD_PARENT="$(dirname "${PWD_ABS}")"

# Build volume mounts; skip optional paths that don't exist on the host
VOLUMES=(
  -v "${PWD_ABS}:${PWD_ABS}"
  -v "/var/run/docker.sock:/var/run/docker-real.sock"
)
[ -d "${HOME}/.aws" ]      && VOLUMES+=(-v "${HOME}/.aws:/home/dev/.aws:ro")
if [ -f "${HOME}/.gitconfig" ]; then
  VOLUMES+=(-v "${HOME}/.gitconfig:/home/dev/.gitconfig:ro")
else
  echo "Warning: ~/.gitconfig not found; git identity will be unavailable in the container" >&2
fi
[ -d "${HOME}/.config/gh" ] && VOLUMES+=(-v "${HOME}/.config/gh:/home/dev/.config/gh:ro")

if [ "$TOOL_FLAVOR" = "codex" ]; then
  TMP_CODEX_OVERRIDE="$(mktemp "${TMPDIR:-/tmp}/codex-agents-override.XXXXXX")"
  if [ -d "${HOME}/.codex" ]; then
    VOLUMES+=(-v "${HOME}/.codex:/home/dev/.codex:rw")
    render_codex_override "${HOME}/.codex" "$TMP_CODEX_OVERRIDE"
  else
    render_codex_override "" "$TMP_CODEX_OVERRIDE"
  fi
  VOLUMES+=(-v "${TMP_CODEX_OVERRIDE}:/home/dev/.codex/AGENTS.override.md:ro")
  if [ ! -f "${HOME}/.codex/agents/memory-bank-analyzer.toml" ] && [ -f "$CODEX_AGENT_ASSET" ]; then
    if [ -d "${HOME}/.codex/agents" ]; then
      VOLUMES+=(-v "${CODEX_AGENT_ASSET}:/home/dev/.codex/agents/memory-bank-analyzer.toml:ro")
    else
      TMP_CODEX_AGENTS_DIR="$(mktemp -d "${TMPDIR:-/tmp}/codex-agents.XXXXXX")"
      cp "$CODEX_AGENT_ASSET" "${TMP_CODEX_AGENTS_DIR}/memory-bank-analyzer.toml"
      VOLUMES+=(-v "${TMP_CODEX_AGENTS_DIR}:/home/dev/.codex/agents:rw")
    fi
  elif [ ! -f "${HOME}/.codex/agents/memory-bank-analyzer.toml" ]; then
    echo "Warning: bundled Codex agent asset not found at ${CODEX_AGENT_ASSET}; memory-bank-analyzer will not be injected" >&2
  fi
elif [ "$TOOL_FLAVOR" = "gemini" ]; then
  [ -d "${HOME}/.gemini" ] && VOLUMES+=(-v "${HOME}/.gemini:/home/dev/.gemini:rw")
  [ -d "${HOME}/.config/gcloud" ] && VOLUMES+=(-v "${HOME}/.config/gcloud:/home/dev/.config/gcloud:rw")
else
  [ -d "${HOME}/.claude" ] && VOLUMES+=(-v "${HOME}/.claude:/home/dev/.claude:rw")
  [ -f "${HOME}/.claude.json" ] && VOLUMES+=(-v "${HOME}/.claude.json:/home/dev/.claude.json:rw")

  # Mount user plugin directory if it exists.
  USER_PLUGINS="${HOME}/.claude-plugins"
  if [ -d "$USER_PLUGINS" ]; then
    VOLUMES+=(-v "${USER_PLUGINS}:/home/dev/user-plugins:ro")
  fi
fi

# Run the dev container
docker run --rm -it \
  "${VOLUMES[@]}" -w "${PWD_ABS}" \
  -e "ALLOWED_MOUNT_BASE=${PWD_PARENT}" \
  -e "ALLOWED_RW_BASE=${PWD_ABS}" \
  ${AWS_PROFILE:+-e "AWS_PROFILE=${AWS_PROFILE}"} \
  ${AWS_REGION:+-e "AWS_REGION=${AWS_REGION}"} \
  ${CLAUDE_CODE_USE_BEDROCK:+-e "CLAUDE_CODE_USE_BEDROCK=${CLAUDE_CODE_USE_BEDROCK}"} \
  ${AI_CLI_GITHUB_TOKEN:+-e "GITHUB_TOKEN=${AI_CLI_GITHUB_TOKEN}"} \
  ${GOOGLE_CLOUD_PROJECT:+-e "GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT}"} \
  ${GOOGLE_CLOUD_LOCATION:+-e "GOOGLE_CLOUD_LOCATION=${GOOGLE_CLOUD_LOCATION}"} \
  ${OPENAI_API_KEY:+-e "OPENAI_API_KEY=${OPENAI_API_KEY}"} \
  "$IMAGE" "$@"
STATUS=$?
exit "$STATUS"
