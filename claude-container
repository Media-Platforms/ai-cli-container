#!/usr/bin/env bash
# claude-dev — launch the Claude Code dev container from any repo

set -euo pipefail

# Get absolute path of current directory
PWD_ABS="$(pwd)"

# Run the dev container, mapping this repo and Docker socket
exec docker run --rm -it \
  -v "${PWD_ABS}:${PWD_ABS}" -w "${PWD_ABS}" \
  -v "${HOME}/.aws:/home/dev/.aws:ro" \
  -v "${HOME}/.claude:/home/dev/.claude:rw" \
  -v "${HOME}/.claude.json:/home/dev/.claude.json:rw" \
  -v "/var/run/docker.sock:/var/run/docker.sock" \
  ${AWS_PROFILE:+-e "AWS_PROFILE=${AWS_PROFILE}"} \
  ${AWS_REGION:+-e "AWS_REGION=${AWS_REGION}"} \
  ${CLAUDE_CODE_USE_BEDROCK:+-e "CLAUDE_CODE_USE_BEDROCK=${CLAUDE_CODE_USE_BEDROCK}"} \
  claude-code-dev:latest "$@"
