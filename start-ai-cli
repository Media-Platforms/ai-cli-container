#!/usr/bin/env bash
set -euo pipefail

# sudo's secure_path drops /home/dev/.local/bin, so set PATH explicitly
DEV_PATH="/home/dev/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
DEV_ENV=(sudo -E -u dev -H env HOME=/home/dev PATH="$DEV_PATH")

REAL_SOCK=/var/run/docker-real.sock
PROXY_SOCK=/var/run/docker.sock
if [ -S "$REAL_SOCK" ]; then
  chmod 700 "$REAL_SOCK"
  python3 /usr/local/bin/docker-socket-proxy &
  for _ in $(seq 1 50); do
    [ -S "$PROXY_SOCK" ] && break
    sleep 0.1
  done
fi

# Inject memory-bank support for Codex / Gemini CLI launches
if [ $# -gt 0 ]; then
  case "$1" in
    gemini)
      # Gemini supports subagents via .gemini/agents/*.md
      SRC_DIR=/home/dev/container-plugin/gemini-agents
      DEST_DIR=/home/dev/.gemini/agents
      if [ -d "$SRC_DIR" ]; then
        mkdir -p "$DEST_DIR"
        for agent in "$SRC_DIR"/*.md; do
          [ -f "$agent" ] || continue
          DEST="$DEST_DIR/$(basename "$agent")"
          [ -f "$DEST" ] || cp "$agent" "$DEST"
        done
        chown -R dev:dev /home/dev/.gemini
      fi
      ;;
  esac
fi

# If first arg doesn't start with '-', run it as a command instead of claude
if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
  exec "${DEV_ENV[@]}" "$@"
fi

# Run claude with container plugin and --dangerously-skip-permissions
# Default model can be overridden by --model in args
CLAUDE_ARGS=(
  --plugin-dir /home/dev/container-plugin
  --dangerously-skip-permissions
)

# Load user-supplied plugins if the directory was mounted
USER_PLUGINS=/home/dev/user-plugins
if [ -d "$USER_PLUGINS" ]; then
  CLAUDE_ARGS+=(--plugin-dir "$USER_PLUGINS")
fi

exec "${DEV_ENV[@]}" claude "${CLAUDE_ARGS[@]}" "$@"
